Range inside a YAML block scalar (expr: |-) should be
embedded as a string interpolation within the multi-line CUE
string, not break out of block scalar context.

-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  expr: |-
    metric{job="test"}
    < on ({{ range .Values.labels }}{{ . }},{{ end }}namespace) group_left
      count by ({{ range .Values.labels }}{{ . }},{{ end }}namespace) (metric{job="test"})
-- values.yaml --
labels:
  - foo
  - bar
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  expr: |-
    metric{job="test"}
    < on (foo,bar,namespace) group_left
      count by (foo,bar,namespace) (metric{job="test"})
-- output.cue --
import "strings"

#values: {
	labels?: [...] | {
		...
	}
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: expr:     """
			metric{job="test"}
			< on (\(strings.Join([for _, _range0 in #values.labels {
			"\(_range0),"
		}], ""))namespace) group_left
			  count by (\(strings.Join([for _, _range0 in #values.labels {
			"\(_range0),"
		}], ""))namespace) (metric{job="test"})
			"""
	},
]
