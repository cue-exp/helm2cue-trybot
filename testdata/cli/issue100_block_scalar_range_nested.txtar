# Block scalar range with nested control structures leaks variable.
# https://github.com/cue-exp/helm2cue/issues/100
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/cm.cue expected/cm.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
replicas: 3
enabled: true
uid: prometheus
-- input/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- input/templates/cm.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  config.yaml: |-
    datasources:
{{- if .Values.enabled }}
{{- range until (int .Values.replicas) }}
    - name: "replica-{{ . }}"
      uid: {{ $.Values.uid }}-{{ . }}
{{- if $.Values.enabled }}
      active: true
{{- end }}
{{- end }}
{{- end }}
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/cm.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import (
	"strings"
	"list"
)

cm: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name:      "test"
		data: "config.yaml": """
			datasources:\([if (_nonzero & {#arg: #values.enabled}).out {
			"\(strings.Join([for _, _range0 in list.Range(0, int & #values.replicas, 1) {
				"\n- name: \"replica-\(_range0)\"\n  uid: \(#values.uid)-\(_range0)\([if (_nonzero & {#arg: #values.enabled}).out {
					"\n  active: true"
				}, ""][0])"
			}], ""))"
		}, ""][0])
			"""
	},
]
