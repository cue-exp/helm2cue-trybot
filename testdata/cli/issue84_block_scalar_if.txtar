# Sequential conditional list items inside a block scalar should
# not be unified into a single element. The converter must embed
# the conditional as a string interpolation within the block scalar.
# https://github.com/cue-exp/helm2cue/issues/84
exec helm2cue chart input output
cmp output/test.cue expected/test.cue

-- input/Chart.yaml --
apiVersion: v2
name: test
version: 0.1.0
-- input/values.yaml --
enabled: true
firstName: Alice
secondName: Bob
-- input/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  datasources: |
    datasources:
{{- if .Values.enabled }}
    - name: {{ .Values.firstName }}
      type: first
{{- end }}
    - name: {{ .Values.secondName }}
      type: second
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name:    "test"
		data: datasources: """
			datasources:\([if (_nonzero & {#arg: #values.enabled}).out {
			"\n- name: \(#values.firstName)\n  type: first"
		}, ""][0])
			- name: \(#values.secondName)
			  type: second
			
			"""
	},
]
