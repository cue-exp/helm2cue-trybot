# Range inside a YAML block scalar (expr: |-) should be
# embedded as a string interpolation, not break out of the
# block scalar context.
# https://github.com/cue-exp/helm2cue/issues/75
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
labels:
  - foo
  - bar
-- chartdir/templates/test.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  expr: |-
    metric{job="test"}
    < on ({{ range .Values.labels }}{{ . }},{{ end }}namespace) group_left
      count by ({{ range .Values.labels }}{{ . }},{{ end }}namespace) (metric{job="test"})
-- stderr.golden --
converted 1/1 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "strings"

test: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: expr:     """
			metric{job="test"}
			< on (\(strings.Join([for _, _range0 in #values.labels {
			"\(_range0),"
		}], ""))namespace) group_left
			  count by (\(strings.Join([for _, _range0 in #values.labels {
			"\(_range0),"
		}], ""))namespace) (metric{job="test"})
			"""
	},
]
