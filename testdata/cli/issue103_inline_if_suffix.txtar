# Inline {{ if }} conditional suffix on a key value causes the
# converter to lose track of YAML nesting. The conditional suffix
# should be part of the name value, and path should be a sibling.
# https://github.com/cue-exp/helm2cue/issues/103
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/webhook.cue expected/webhook.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
deployWebhook: true
-- input/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- input/templates/webhook.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  webhooks:
  - clientConfig:
      service:
        name: my-service{{ if .Values.deployWebhook }}-webhook{{ end }}
        path: /validate
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/webhook.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

webhook: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "test"
		data: webhooks: [
			{
				clientConfig: service: {
					if (_nonzero & {#arg: #values.deployWebhook}).out {
						name: "my-service-webhook"
					}
					if !((_nonzero & {#arg: #values.deployWebhook}).out) {
						name: "my-service"
					}, path: "/validate"
				}
			},
		]
	},
]
