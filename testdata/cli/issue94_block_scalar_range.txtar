# Range inside block scalar leaks variable scope.
# https://github.com/cue-exp/helm2cue/issues/94
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/cm.cue expected/cm.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
replicas: 3
-- input/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- input/templates/cm.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: test
data:
  config.yaml: |-
    primary:
      name: primary
{{- range until (int .Values.replicas) }}
    - name: "replica-{{ . }}"
{{- end }}
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/cm.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import (
	"strings"
	"list"
)

cm: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name:      "test"
		data: "config.yaml": """
			primary:
			  name: primary
			\(strings.Join([for _, _range0 in list.Range(0, int & #values.replicas, 1) {
			"- name: \"replica-\(_range0)\""
		}], "\n"))
			"""
	},
]
