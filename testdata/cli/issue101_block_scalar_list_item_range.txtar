# Block scalar on a YAML list item (- value: |-) with inline range
# is not recognized as a block scalar.
# https://github.com/cue-exp/helm2cue/issues/101
exec helm2cue chart input output
cmp stderr stderr.golden
cmp output/rules.cue expected/rules.cue

-- input/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- input/values.yaml --
labels:
  - env
-- input/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- input/templates/rules.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: rules
data:
  items:
    - value: |-
        sum by ({{ range .Values.labels }}{{ . }},{{ end }}cluster) (
          rate(total[5m])
        )
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/rules.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

import "strings"

rules: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "rules"
		data: items: [
			{
				value: """
					sum by (\(strings.Join([for _, _range0 in #values.labels {
					"\(_range0),"
				}], ""))cluster) (
					  rate(total[5m])
					)
					"""
			},
		]
	},
]
