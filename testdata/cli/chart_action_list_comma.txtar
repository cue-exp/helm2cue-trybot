# Action nodes inside a block scalar list item should produce
# a single CUE multi-line string with inline interpolations.
# https://github.com/cue-exp/helm2cue/issues/67
exec helm2cue chart chartdir outdir
cmp stderr stderr.golden
cmp outdir/test.cue expected/test.cue

-- chartdir/Chart.yaml --
apiVersion: v2
name: test-app
version: 0.1.0
-- chartdir/values.yaml --
branch: main
interval: 60
-- chartdir/templates/test.yaml --
command:
  - /bin/bash
  - -ec
  - |
    pull origin {{ .Values.branch }}
    sleep {{ .Values.interval }}
-- chartdir/templates/good.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: good
data:
  key: value
-- stderr.golden --
converted 2/2 templates from test-app
-- expected/test.cue --
// Code generated by helm2cue; DO NOT EDIT.

package test_app

test: [
	{
		command: [
			"/bin/bash",
			"-ec",
			"""
				pull origin \(#values.branch)
				sleep \(#values.interval)
				
				""",
		]
	},
]
