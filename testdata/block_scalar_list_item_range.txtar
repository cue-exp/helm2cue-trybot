Block scalar on a YAML list item (- value: |-) with inline range
should be recognized as a block scalar and emitted as a CUE
multi-line string.
-- values.yaml --
labels:
  - env
-- input.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: rules
data:
  items:
    - value: |-
        sum by ({{ range .Values.labels }}{{ . }},{{ end }}cluster) (
          rate(total[5m])
        )
-- helm_output.yaml --
apiVersion: v1
kind: ConfigMap
metadata:
  name: rules
data:
  items:
    - value: |-
        sum by (env,cluster) (
          rate(total[5m])
        )
-- output.cue --
import "strings"

#values: {
	labels?: [...] | {
		...
	}
	...
}

output: [
	{
		apiVersion: "v1"
		kind:       "ConfigMap"
		metadata: name: "rules"
		data: items: [
			{
				value: """
					sum by (\(strings.Join([for _, _range0 in #values.labels {
					"\(_range0),"
				}], ""))cluster) (
					  rate(total[5m])
					)
					"""
			},
		]
	},
]
